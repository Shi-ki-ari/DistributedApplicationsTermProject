@page
@model StatusPageRazorUI.Pages.EngineersModel

<h1 class="mb-4">Engineers</h1>

<div class="d-flex justify-content-end mb-3">
    <button class="btn btn-success" type="button" data-bs-toggle="modal" data-bs-target="#addEngineerModal">
        Add Engineer
    </button>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input class="form-control" name="SearchTerm" value="@Model.SearchTerm" placeholder="Search name..." />
    </div>
    <div class="col-md-3">
        <input class="form-control" name="SearchEmail" value="@Model.SearchEmail" placeholder="Search email..." />
    </div>
    <div class="col-md-2">
        <select class="form-select" name="SortBy">
            <option value="">Sort by (default)</option>
            <option value="name" selected="@(Model.SortBy == "name")">Name</option>
            <option value="email" selected="@(Model.SortBy == "email")">Email</option>
            <option value="hireddate" selected="@(Model.SortBy == "hireddate")">Hired Date</option>
            <option value="hourlyrate" selected="@(Model.SortBy == "hourlyrate")">Hourly Rate</option>
        </select>
    </div>
    <div class="col-md-3">
        <select class="form-select" name="SortDescending">
            <option value="false" selected="@(!Model.SortDescending)">Ascending</option>
            <option value="true" selected="@(Model.SortDescending)">Descending</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Apply</button>
    </div>
    <input type="hidden" name="PageSize" value="@Model.PageSize" />
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Engineers.Items.Any())
        {
            foreach (var engineer in Model.Engineers.Items)
            {
                <tr>
                    <td>@engineer.Id</td>
                    <td>@engineer.Name</td>
                    <td class="text-end">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#engineerDetails-@engineer.Id">
                            View
                        </button>

                        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#editEngineerModal-@engineer.Id">
                            Edit
                        </button>

                        <form method="post" asp-page-handler="Delete" class="d-inline">
                            <input type="hidden" name="id" value="@engineer.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" class="text-center">No engineers found.</td>
            </tr>
        }
    </tbody>
</table>

@if (Model.Engineers.Items.Any())
{
    foreach (var engineer in Model.Engineers.Items)
    {
        <div class="modal fade" id="engineerDetails-@engineer.Id" tabindex="-1" aria-labelledby="engineerDetailsLabel-@engineer.Id" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="engineerDetailsLabel-@engineer.Id">Engineer Details</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Name</dt>
                            <dd class="col-sm-8">@engineer.Name</dd>
                            <dt class="col-sm-4">Email</dt>
                            <dd class="col-sm-8">@engineer.Email</dd>
                            <dt class="col-sm-4">Hired Date</dt>
                            <dd class="col-sm-8">@engineer.HiredDate.ToString("yyyy-MM-dd")</dd>
                            <dt class="col-sm-4">On Call</dt>
                            <dd class="col-sm-8">@(engineer.OnCall ? "Yes" : "No")</dd>
                            <dt class="col-sm-4">Hourly Rate</dt>
                            <dd class="col-sm-8">@engineer.HourlyRate</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="editEngineerModal-@engineer.Id" tabindex="-1" aria-labelledby="editEngineerModalLabel-@engineer.Id" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="editEngineerModalLabel-@engineer.Id">Edit Engineer</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form method="post" asp-page-handler="Edit">
                        <div class="modal-body">
                            <input type="hidden" name="id" value="@engineer.Id" />

                            <div class="mb-3">
                                <label class="form-label">Name</label>
                                <input name="name" class="form-control" value="@engineer.Name" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input name="email" type="email" class="form-control" value="@engineer.Email" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Hired Date</label>
                                <input name="hiredDate" type="date" class="form-control" value="@engineer.HiredDate.ToString("yyyy-MM-dd")" />
                            </div>
                            <div class="mb-3 form-check">
                                <input name="onCall" type="checkbox" class="form-check-input" value="true" @(engineer.OnCall ? "checked" : "") />
                                <label class="form-check-label">On Call</label>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Hourly Rate</label>
                                <input name="hourlyRate" type="number" step="0.01" min="0" class="form-control" value="@engineer.HourlyRate" />
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}

<div class="modal fade" id="addEngineerModal" tabindex="-1" aria-labelledby="addEngineerModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addEngineerModalLabel">Add Engineer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="engineerName" class="form-label">Name</label>
                        <input id="engineerName" name="name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label for="engineerEmail" class="form-label">Email</label>
                        <input id="engineerEmail" name="email" type="email" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label for="engineerHiredDate" class="form-label">Hired Date</label>
                        <input id="engineerHiredDate" name="hiredDate" type="date" class="form-control" />
                    </div>
                    <div class="mb-3 form-check">
                        <input id="engineerOnCall" name="onCall" type="checkbox" class="form-check-input" value="true" />
                        <label class="form-check-label" for="engineerOnCall">On Call</label>
                    </div>
                    <div class="mb-3">
                        <label for="engineerHourlyRate" class="form-label">Hourly Rate</label>
                        <input id="engineerHourlyRate" name="hourlyRate" type="number" step="0.01" min="0" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<nav aria-label="Engineers pagination">
    <ul class="pagination justify-content-center">
        <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : string.Empty)">
            <a class="page-link"
               asp-page="/Engineers"
               asp-route-PageNumber="@(Model.PageNumber - 1)"
               asp-route-PageSize="@Model.PageSize"
               asp-route-SearchTerm="@Model.SearchTerm">Previous</a>
        </li>
        <li class="page-item disabled">
            <span class="page-link">Page @Model.PageNumber of @Model.Engineers.TotalPages</span>
        </li>
        <li class="page-item @(Model.PageNumber >= Model.Engineers.TotalPages ? "disabled" : string.Empty)">
            <a class="page-link"
               asp-page="/Engineers"
               asp-route-PageNumber="@(Model.PageNumber + 1)"
               asp-route-PageSize="@Model.PageSize"
               asp-route-SearchTerm="@Model.SearchTerm">Next</a>
        </li>
    </ul>
</nav>